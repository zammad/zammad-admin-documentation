msgid "Ticket Pending Time Reached ``Time event activator only``"
msgstr "Tempo pendente do ticket atingido (``somente ativador Time event``)"

#: ../manage/webhook/examples/generic-notifications-trigger.rst:53
msgid ""
"Select ticket **Pending till** attribute and set the operator to *has "
"reached*."
msgstr ""
"Selecione o atributo **Pending till** do ticket e defina o operador como "
"*has reached*."

#: ../manage/webhook/examples/generic-notifications-trigger.rst:58
msgid "Ticket Escalation Time Reached ``Time event activator only``"
msgstr ""
"Tempo de escalonamento do ticket atingido (``somente ativador Time event``)"

#: ../manage/webhook/examples/generic-notifications-trigger.rst:57
msgid ""
"Select ticket **Escalation at** attribute and set the operator to *has "
"reached*."
msgstr ""
"Selecione o atributo **Escalation at** do ticket e defina o operador como "
"*has reached*."

#: ../manage/webhook/examples/generic-notifications-trigger.rst:62
