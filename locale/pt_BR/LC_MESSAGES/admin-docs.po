msgid ""
"Select ticket **Action** attribute, leave the operator on *is* and set the "
"value to *created*."
msgstr ""
"Selecione o atributo **Action** do ticket, deixe o operador em *is* e defina "
"o valor como *created*."

#: ../manage/webhook/examples/generic-notifications-trigger.rst:50
msgid "Ticket Updated ``Action activator only``"
msgstr "Ticket atualizado (``somente ativador Action``)"

#: ../manage/webhook/examples/generic-notifications-trigger.rst:49
msgid ""
"Select ticket **Action** attribute, leave the operator on *is* and set the "
"value to *updated*."
msgstr ""
"Selecione o atributo **Action** do ticket, deixe o operador em *is* e defina "
"o valor como *updated*."

