#: ../manage/webhook/examples/microsoft-teams-notifications.rst:None
msgid "Creating Incoming Webhook Connector"
msgstr "Creazione del connettore webhook in entrata"

#: ../manage/webhook/examples/microsoft-teams-notifications.rst:60
msgid "Click on **Create** and be patient."
msgstr "Fai clic su **Crea** e sii paziente."

#: ../manage/webhook/examples/microsoft-teams-notifications.rst:None
msgid "Copying Incoming Webhook Connector URL"
msgstr "Copia dell'URL del connettore webhook in entrata"

#: ../manage/webhook/examples/microsoft-teams-notifications.rst:70
