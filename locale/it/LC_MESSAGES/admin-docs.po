msgstr "Rete"

#: ../settings/system/network.rst:8
msgid ""
"The proxy settings can only be saved after successfully testing the proxy "
"connection."
msgstr ""
"Le impostazioni del proxy possono essere salvate solo dopo aver testato con "
"successo la connessione al proxy."

#: ../settings/system/network.rst:15
