#: ../settings/branding.rst:25
msgid "User preferences (if Zammad can't detect the users locale)"
msgstr ""
"Preferenze utente (se Zammad non riesce a rilevare la locale dell'utente)"

#: ../settings/branding.rst:26
msgid "CSV output (reporting, time accounting)"
msgstr "Output CSV (reporting, contabilità oraria)"

#: ../settings/branding.rst:30
msgid "Define the timezone of your Zammad installation."
msgstr "Definisci il fuso orario della tua installazione Zammad."

#: ../settings/branding.rst:32
msgid ""
"This does not have any effect on timings for your agents or how Zammad "
"stores date and time values."
msgstr ""
"Ciò non ha alcun effetto sui tempi per i tuoi agenti o su come Zammad "
"memorizza i valori di data e ora."

#: ../settings/branding.rst:35
msgid "Changing this value has direct consequences on the following areas:"
msgstr ""
"La modifica di questo valore ha conseguenze dirette sulle seguenti aree:"

#: ../settings/branding.rst:37
