msgstr ""
":doc:`tramite integrazione LDAP/Active Directory </system/integrations/ldap/"
"index>`"

#: ../manage/users/index.rst:22
msgid ":doc:`via Exchange integration </system/integrations/exchange>`"
msgstr ":doc:`tramite integrazione Exchange </system/integrations/exchange>`"

